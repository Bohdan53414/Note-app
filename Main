          <option value="work">💼 Робота</option>
          <option value="ideas">💡 Ідеї</option>
          <option value="urgent">🔥 Термінове</option>
        </select>
        <div class="toolbar-sep"></div>
        <span style="font-size:11px; color:var(--text-dim)" id="last-saved-label">Не збережено</span>
        <button class="editor-save-btn" onclick="saveCurrentNote()">💾 Зберегти</button>
      </div>
      <div class="editor-body" style="display:flex;flex-direction:column;flex:1;overflow:hidden">
        <input type="text" class="editor-title-input" id="editor-title" placeholder="Назва нотатки…" oninput="markUnsaved()" />
        <textarea class="editor-content-input" id="editor-content" placeholder="Почніть писати нотатку тут…" oninput="markUnsaved()"></textarea>
      </div>
    </div>
  </div>
</div>

<!-- DELETE MODAL -->
<div class="modal-backdrop" id="delete-modal">
  <div class="modal">
    <h3>Видалити нотатку?</h3>
    <p>Ця дія незворотна. Нотатку буде видалено назавжди.</p>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeDeleteModal()">Скасувати</button>
      <button class="btn-confirm-del" onclick="confirmDelete()">Видалити</button>
    </div>
  </div>
</div>

<!-- TOAST CONTAINER -->
<div class="toast-container" id="toast-container"></div>

<script>
// ══════════════════════════════════════
//  STATE
// ══════════════════════════════════════
let users = JSON.parse(localStorage.getItem('nf_users') || '[]');
let sessions = JSON.parse(localStorage.getItem('nf_sessions') || '{}');
let currentUser = null;
let notes = [];
let activeNoteId = null;
let currentFilter = 'all';
let searchQuery = '';
let deleteTargetId = null;
let unsaved = false;

// ══════════════════════════════════════
//  BOOT
// ══════════════════════════════════════
function boot() {
  const sid = localStorage.getItem('nf_sid');
  if (sid && sessions[sid]) {
    currentUser = sessions[sid];
    loadApp();
  }
}

// ══════════════════════════════════════
//  AUTH
// ══════════════════════════════════════
function switchTab(tab) {
  document.getElementById('form-login').style.display = tab === 'login' ? '' : 'none';
  document.getElementById('form-register').style.display = tab === 'register' ? '' : 'none';
  document.getElementById('tab-login').classList.toggle('active', tab === 'login');
  document.getElementById('tab-register').classList.toggle('active', tab === 'register');
  document.getElementById('auth-error').style.display = 'none';
}

function showAuthError(msg) {
  const el = document.getElementById('auth-error');
  el.textContent = msg;
  el.style.display = 'block';
}

function handleLogin() {
  const email = document.getElementById('login-email').value.trim();
  const pass = document.getElementById('login-pass').value;
  if (!email || !pass) return showAuthError('Заповніть всі поля');
  const user = users.find(u => u.email === email && u.password === hashPass(pass));
  if (!user) return showAuthError('Невірний email або пароль');
  createSession(user);
}

function handleRegister() {
  const name = document.getElementById('reg-name').value.trim();
  const email = document.getElementById('reg-email').value.trim();
  const pass = document.getElementById('reg-pass').value;
  const pass2 = document.getElementById('reg-pass2').value;
  if (!name || !email || !pass || !pass2) return showAuthError('Заповніть всі поля');
  if (!email.includes('@')) return showAuthError('Введіть коректний email');
  if (pass.length < 6) return showAuthError('Пароль має бути не менше 6 символів');
  if (pass !== pass2) return showAuthError('Паролі не збігаються');
  if (users.find(u => u.email === email)) return showAuthError('Цей email вже зареєстрований');
  const user = { id: Date.now().toString(), name, email, password: hashPass(pass), createdAt: new Date().toISOString() };
  users.push(user);
  localStorage.setItem('nf_users', JSON.stringify(users));
  createSession(user);
}

function hashPass(p) {
  let h = 0;
  for (let i = 0; i < p.length; i++) h = Math.imul(31, h) + p.charCodeAt(i) | 0;
  return h.toString(36) + p.length;
}

function createSession(user) {
  const sid = Math.random().toString(36).slice(2) + Date.now().toString(36);
  sessions[sid] = user;
  localStorage.setItem('nf_sessions', JSON.stringify(sessions));
  localStorage.setItem('nf_sid', sid);
  currentUser = user;
  loadApp();
}

function handleLogout() {
  const sid = localStorage.getItem('nf_sid');
  delete sessions[sid];
  localStorage.setItem('nf_sessions', JSON.stringify(sessions));
  localStorage.removeItem('nf_sid');
  currentUser = null;
  notes = [];
  activeNoteId = null;
  document.getElementById('app-screen').style.display = 'none';
  document.getElementById('auth-screen').style.display = 'flex';
  document.getElementById('login-email').value = '';
  document.getElementById('login-pass').value = '';
}

// ══════════════════════════════════════
//  APP LOAD
// ══════════════════════════════════════
function loadApp() {
  document.getElementById('auth-screen').style.display = 'none';
  document.getElementById('app-screen').style.display = 'flex';
  document.getElementById('user-display-name').textContent = currentUser.name;
  document.getElementById('user-avatar-text').textContent = currentUser.name.charAt(0).toUpperCase();
  notes = JSON.parse(localStorage.getItem('nf_notes_' + currentUser.id) || '[]');
  renderNotesList();
  updateCounts();
}

// ══════════════════════════════════════
//  NOTES CRUD
// ══════════════════════════════════════
function saveNotes() {
  localStorage.setItem('nf_notes_' + currentUser.id, JSON.stringify(notes));
}

function createNewNote() {
  const note = {
    id: Date.now().toString(),
    title: '',
    content: '',
    category: 'personal',
    createdAt: new Date().toISOString(),
    updatedAt: new Date().toISOString()
  };
  notes.unshift(note);
  saveNotes();
  currentFilter = 'all';
  searchQuery = '';
  document.getElementById('search-input').value = '';
  document.querySelectorAll('.cat-item').forEach(b => b.classList.remove('active'));
  document.querySelector('[data-cat="all"]').classList.add('active');
  renderNotesList();
  updateCounts();
  openNote(note.id);
  setTimeout(() => document.getElementById('editor-title').focus(), 50);
}

function openNote(id) {
  activeNoteId = id;
  const note = notes.find(n => n.id === id);
  if (!note) return;
  document.getElementById('editor-empty').style.display = 'none';
  document.getElementById('editor-active').style.display = 'flex';
  document.getElementById('editor-title').value = note.title;
  document.getElementById('editor-content').value = note.content;
  document.getElementById('cat-select').value = note.category;
  document.getElementById('last-saved-label').textContent = 'Збережено: ' + fmtDate(note.updatedAt);
  unsaved = false;
  renderNotesList();
}

function saveCurrentNote() {
  if (!activeNoteId) return;
  const note = notes.find(n => n.id === activeNoteId);
  if (!note) return;
  note.title = document.getElementById('editor-title').value.trim() || 'Без назви';
  note.content = document.getElementById('editor-content').value;
  note.category = document.getElementById('cat-select').value;
  note.updatedAt = new Date().toISOString();
  const idx = notes.findIndex(n => n.id === activeNoteId);
  notes.splice(idx, 1);
  notes.unshift(note);
  saveNotes();
  unsaved = false;
  document.getElementById('last-saved-label').textContent = 'Збережено: ' + fmtDate(note.updatedAt);
  renderNotesList();
  updateCounts();
  showToast('Нотатку збережено', 'success');
}

function updateNoteCategory(cat) {
  if (!activeNoteId) return;
  markUnsaved();
}

function deleteNote(id) {
  deleteTargetId = id;
  document.getElementById('delete-modal').style.display = 'flex';
}

function closeDeleteModal() {
  document.getElementById('delete-modal').style.display = 'none';
  deleteTargetId = null;
}

function confirmDelete() {
  if (!deleteTargetId) return;
  notes = notes.filter(n => n.id !== deleteTargetId);
  saveNotes();
  if (activeNoteId === deleteTargetId) {
    activeNoteId = null;
    document.getElementById('editor-empty').style.display = 'flex';
    document.getElementById('editor-active').style.display = 'none';
  }
  deleteTargetId = null;
  closeDeleteModal();
  renderNotesList();
  updateCounts();
  showToast('Нотатку видалено', 'error');
}

function markUnsaved() {
  unsaved = true;
  document.getElementById('last-saved-label').textContent = 'Не збережено';
}

// ══════════════════════════════════════
//  FILTER & SEARCH
// ══════════════════════════════════════
function filterByCategory(cat, el) {
  currentFilter = cat;
  document.querySelectorAll('.cat-item').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  const titles = { all: 'Всі нотатки', personal: 'Особисте', work: 'Робота', ideas: 'Ідеї', urgent: 'Термінове' };
  document.getElementById('list-title').textContent = titles[cat];
  renderNotesList();
}

function handleSearch(val) {
  searchQuery = val.toLowerCase();
  renderNotesList();
}

function getFilteredNotes() {
  let list = [...notes];
  if (currentFilter !== 'all') list = list.filter(n => n.category === currentFilter);
  if (searchQuery) list = list.filter(n =>
    n.title.toLowerCase().includes(searchQuery) || n.content.toLowerCase().includes(searchQuery)
  );
  return list;
}

// ══════════════════════════════════════
//  RENDER
// ══════════════════════════════════════
const catLabels = { personal: '👤 Особисте', work: '💼 Робота', ideas: '💡 Ідеї', urgent: '🔥 Термінове' };
const catColors = { personal: 'var(--cat-personal)', work: 'var(--cat-work)', ideas: 'var(--cat-ideas)', urgent: 'var(--cat-urgent)' };

function renderNotesList() {
  const list = getFilteredNotes();
  document.getElementById('list-count').textContent = list.length;
  const container = document.getElementById('notes-list');

  if (!list.length) {
    container.innerHTML = `<div class="empty-notes"><div class="empty-icon">📭</div>Нотаток не знайдено</div>`;
    return;
  }

  container.innerHTML = list.map(n => `
    <div class="note-card ${n.id === activeNoteId ? 'active' : ''}" onclick="openNote('${n.id}')">
      <div class="note-card-cat" style="background:${catColors[n.category]}"></div>
      <div class="note-card-title">${esc(n.title || 'Без назви')}</div>
      <div class="note-card-preview">${esc(n.content) || '<em style="color:var(--text-dim)">Порожня нотатка</em>'}</div>
      <div class="note-card-meta">
        <span class="note-card-date">${fmtDate(n.updatedAt)}</span>
        <span class="note-card-tag cat-${n.category}">${catLabels[n.category]}</span>
      </div>
      <button class="note-card-del" onclick="event.stopPropagation(); deleteNote('${n.id}')" title="Видалити">🗑</button>
    </div>
  `).join('');
}

function updateCounts() {
  document.getElementById('count-all').textContent = notes.length;
  document.getElementById('count-personal').textContent = notes.filter(n => n.category === 'personal').length;
  document.getElementById('count-work').textContent = notes.filter(n => n.category === 'work').length;
  document.getElementById('count-ideas').textContent = notes.filter(n => n.category === 'ideas').length;
  document.getElementById('count-urgent').textContent = notes.filter(n => n.category === 'urgent').length;
}

// ══════════════════════════════════════
//  TEXT FORMAT
// ══════════════════════════════════════
function formatText(cmd) {
  const ta = document.getElementById('editor-content');
  const start = ta.selectionStart, end = ta.selectionEnd;
  const sel = ta.value.substring(start, end);
  if (!sel) return;
  const tags = { bold: ['**', '**'], italic: ['_', '_'], underline: ['<u>', '</u>'] };
  const [o, c] = tags[cmd];
  ta.value = ta.value.substring(0, start) + o + sel + c + ta.value.substring(end);
  ta.selectionStart = start; ta.selectionEnd = end + o.length + c.length;
  ta.focus(); markUnsaved();
}

// ══════════════════════════════════════
//  UTILS
// ══════════════════════════════════════
function fmtDate(iso) {
  const d = new Date(iso);
  const now = new Date();
  const diff = (now - d) / 1000;
  if (diff < 60) return 'щойно';
  if (diff < 3600) return Math.floor(diff / 60) + ' хв тому';
  if (diff < 86400) return Math.floor(diff / 3600) + ' год тому';
  return d.toLocaleDateString('uk-UA', { day: 'numeric', month: 'short' });
}

function esc(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function showToast(msg, type = 'success') {
  const c = document.getElementById('toast-container');
  const t = document.createElement('div');
  t.className = `toast ${type}`;
  t.textContent = (type === 'success' ? '✓ ' : '✕ ') + msg;
  c.appendChild(t);
  setTimeout(() => t.remove(), 3000);
}

// Keyboard shortcut: Ctrl+S
document.addEventListener('keydown', e => {
  if ((e.ctrlKey || e.metaKey) && e.key === 's') { e.preventDefault(); saveCurrentNote(); }
  if (e.key === 'Escape') closeDeleteModal();
});

boot();
</script>
</body>
</html>
